-- Hàm tải và chạy script
local function loadScript(url)
    local success, result = pcall(function()
        return game:HttpGet(url)
    end)
    if success and result and result ~= "" then
        loadstring(result)()
    else
        warn("Không thể tải script:", result)
    end
end

-- Kiểm tra biến name
if getgenv().name and scripts[getgenv().name] then
    loadScript(scripts[getgenv().name])
else
    warn("Tên script không hợp lệ hoặc chưa đặt biến môi trường 'name'.")
end
